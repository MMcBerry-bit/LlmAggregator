<UserControl x:Class="LlmAggregator.ToolWindow1Control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Name="MyToolWindow">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="10">
            <TextBlock FontSize="16" HorizontalAlignment="Center">ToolWindow1</TextBlock>
            <TextBox Name="PromptTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,10,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Aggregate" Click="aggregateButton_Click" Width="100" Margin="5"/>
                <Button Content="Show Options" Click="button1_Click" Width="100" Margin="5"/>
                <Button Content="Configure Endpoints" Click="configureEndpoints_Click" Width="140" Margin="5"/>
            </StackPanel>
            <TextBlock Text="Aggregated Result:" Margin="0,10,0,0"/>
            <TextBox Name="ResultTextBox" Height="200" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True"/>
        </StackPanel>
    </Grid>
</UserControl>
